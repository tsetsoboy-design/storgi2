    </div></div>`;
}

function buildPsPanel(ci, ri, si, psi, ps) {
  const ingRows = ps.ingredients.map((ing,ii) => `
    <tr>
      <td style="font-weight:600">${ing.product}</td>
      <td><span class="badge b-blue" style="font-size:10px">${ing.supplier}</span></td>
