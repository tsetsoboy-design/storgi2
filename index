function confirmSendToLeftovers(logIdx, eid) {
  const entry = usedLog[logIdx];
  if (!entry) return;
  const qty     = parseFloat(document.getElementById(`lf-qty-${eid}`)?.value);
  const unit    = document.getElementById(`lf-unit-${eid}`)?.value || 'g';
